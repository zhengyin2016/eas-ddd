<?xml version="1.0" encoding="UTF-8"?>
<project xmlns="http://maven.apache.org/POM/4.0.0"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://maven.apache.org/POM/4.0.0 https://maven.apache.org/xsd/maven-4.0.0.xsd">
    <modelVersion>4.0.0</modelVersion>

    <parent>
        <groupId>com.eas</groupId>
        <artifactId>eas-ddd</artifactId>
        <version>1.0.0-SNAPSHOT</version>
    </parent>

    <artifactId>eas-entry</artifactId>
    <packaging>jar</packaging>
    <name>EAS Entry - 启动入口</name>
    <description>EAS系统启动入口，聚合所有限界上下文模块</description>

    <dependencies>
        <!-- 核心上下文 -->
        <dependency>
            <groupId>com.eas</groupId>
            <artifactId>eas-order-context</artifactId>
        </dependency>
        <dependency>
            <groupId>com.eas</groupId>
            <artifactId>eas-contract-context</artifactId>
        </dependency>
        <dependency>
            <groupId>com.eas</groupId>
            <artifactId>eas-employee-context</artifactId>
        </dependency>
        <dependency>
            <groupId>com.eas</groupId>
            <artifactId>eas-talent-context</artifactId>
        </dependency>
        <dependency>
            <groupId>com.eas</groupId>
            <artifactId>eas-recruitment-context</artifactId>
        </dependency>
        <dependency>
            <groupId>com.eas</groupId>
            <artifactId>eas-project-context</artifactId>
        </dependency>
        <dependency>
            <groupId>com.eas</groupId>
            <artifactId>eas-training-context</artifactId>
        </dependency>
        <dependency>
            <groupId>com.eas</groupId>
            <artifactId>eas-analytics-context</artifactId>
        </dependency>
        <!-- 支撑上下文 -->
        <dependency>
            <groupId>com.eas</groupId>
            <artifactId>eas-file-context</artifactId>
        </dependency>
        <dependency>
            <groupId>com.eas</groupId>
            <artifactId>eas-oa-context</artifactId>
        </dependency>
        <!-- 通用上下文 -->
        <dependency>
            <groupId>com.eas</groupId>
            <artifactId>eas-org-context</artifactId>
        </dependency>
        <dependency>
            <groupId>com.eas</groupId>
            <artifactId>eas-auth-context</artifactId>
        </dependency>
        <!-- Web -->
        <dependency>
            <groupId>org.springframework.boot</groupId>
            <artifactId>spring-boot-starter-web</artifactId>
        </dependency>
    </dependencies>

    <build>
        <plugins>
            <plugin>
                <groupId>org.springframework.boot</groupId>
                <artifactId>spring-boot-maven-plugin</artifactId>
            </plugin>
        </plugins>
    </build>

</project>
