                <version>${project.version}</version>
            </dependency>
            <dependency>
                <groupId>com.eas</groupId>
                <artifactId>eas-auth-context</artifactId>
                <version>${project.version}</version>
            </dependency>
            <dependency>
                <groupId>com.eas</groupId>
                <artifactId>eas-entry</artifactId>
