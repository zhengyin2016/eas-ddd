<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.eas.hr.southbound.adapter.repository.EmployeeMapper">

    <resultMap id="employeeResultMap" type="com.eas.hr.southbound.adapter.repository.EmployeeMapper$EmployeeDO">
        <id property="id" column="id"/>
        <result property="name" column="name"/>
        <result property="gender" column="gender" javaType="com.eas.hr.domain.employee.Gender"/>
        <result property="idCard" column="id_card"/>
        <result property="phone" column="phone"/>
        <result property="email" column="email"/>
        <result property="status" column="status" javaType="com.eas.hr.domain.employee.EmployeeStatus"/>
        <result property="hireDate" column="hire_date"/>
        <result property="departmentId" column="department_id"/>
        <result property="positionId" column="position_id"/>
        <result property="createdAt" column="created_at"/>
        <result property="updatedAt" column="updated_at"/>
    </resultMap>

</mapper>
